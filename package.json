{
  "name": "talent-finder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A RAG AI application to find specific skill matches from a pool of candidates resumes, CVs, and other documents.",
  "keywords": [
    "ai",
    "rag",
    "aws",
    "bedrock",
    "lambda",
    "react",
    "typescript"
  ],
  "author": "Matthew Warman",
  "repository": {
    "type": "git",
    "url": "https://github.com/mwarman/talent-finder.git"
  },
  "license": "MIT",
  "workspaces": [
    "packages/shared",
    "packages/api",
    "packages/web",
    "packages/infra"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present"
  },
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@typescript-eslint/eslint-plugin": "8.59.4",
    "@typescript-eslint/parser": "8.59.4",
    "@vitest/coverage-v8": "4.1.7",
    "eslint": "9.39.4",
    "husky": "9.1.7",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "rimraf": "6.1.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.4",
    "vitest": "4.1.7"
  },
  "engines": {
    "node": ">=24.15.0 < 25"
  }
}
