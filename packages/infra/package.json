{
  "name": "@talent-finder/infra",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "cdk": "cdk",
    "cdk:deploy": "cdk deploy --all --require-approval never",
    "cdk:destroy": "cdk destroy --all --force",
    "precdk:synth": "npm run build",
    "cdk:synth": "cdk synth",
    "clean": "rimraf cdk.out coverage dist",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "dotenv": "17.4.2"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.7",
    "aws-cdk": "2.1124.1",
    "aws-cdk-lib": "2.257.0",
    "constructs": "10.6.0",
    "esbuild": "0.28.0",
    "vitest": "4.1.7"
  }
}
