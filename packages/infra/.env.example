# CDK Configuration
# These environment variables configure the CDK app and resource provisioning.
# AWS credentials are sourced from the standard credential chain:
# - AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY environment variables
# - ~/.aws/credentials file
# - IAM instance profile (when running on EC2/Lambda/ECS)

# Application name (optional, defaults to "talent-finder")
CDK_APP_NAME=talent-finder

# Environment identifier (required)
# Examples: dev, staging, prod
CDK_ENV_NAME=dev

# Organization/OU identifier (required)
# Used for resource tagging and organization
CDK_ORGANIZATION_UNIT=engineering

# Resource owner (required)
# Team or person responsible for provisioned resources
# Used for billing and resource tracking
CDK_RESOURCE_OWNER=team-backend

# Lambda logging level (optional, defaults to "info")
# Valid values: trace, debug, info, warn, error, fatal
CDK_LOG_LEVEL=info

# Lambda logging format (optional, defaults to "json")
# Examples: json, text
CDK_LOG_FORMAT=json

# Enable Lambda logging (optional, defaults to "true")
CDK_LOG_ENABLED=true

# Pinecone index host URL (required)
# Obtained from the Pinecone console after creating a Serverless index.
# See docs/INFRASTRUCTURE_GUIDE.md — Manual Pinecone Setup
CDK_PINECONE_INDEX_HOST=https://your-pinecone-index.svc.pinecone.io

# Pinecone API key (required, sensitive)
# Written into Secrets Manager at deploy time. Bedrock validates this key when
# provisioning the Knowledge Base — the deploy will fail with an invalid key.
# WARNING: Do NOT commit this file with a real API key. Use GitHub Actions secrets
# for CI/CD deployments. See docs/DEVOPS_GUIDE.md — Secrets.
CDK_PINECONE_API_KEY=your-pinecone-api-key

# Bedrock model ID for query generation (optional, defaults to "us.anthropic.claude-sonnet-4-6")
# Supports geo-inference models that may be invoked in multiple AWS regions.
# See https://docs.aws.amazon.com/bedrock/latest/userguide/model-ids.html
CDK_BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# Number of top chunks to retrieve from Knowledge Base (optional, defaults to 5)
CDK_BEDROCK_RETRIEVE_TOP_K=5

# Maximum tokens in model response for query generation (optional, defaults to 1500)
CDK_BEDROCK_MAX_TOKENS=1500